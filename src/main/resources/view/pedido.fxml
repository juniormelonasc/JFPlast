<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.jfplastic.controller.PedidoController"
      style="-fx-padding: 20;">

    <Label text="Cadastro de Pedido" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a237e;" />

    <GridPane hgap="10" vgap="10">
        <Label text="Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="comboCliente" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250" />

        <Label text="Data do Pedido:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <DatePicker fx:id="dateDataPedido" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="150" />

        <Label text="Data de Entrega:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <DatePicker fx:id="dateDataEntrega" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="150" />

        <Label text="Local de entrega:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="txtObservacoes" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="400" />
    </GridPane>

    <Separator />

    <Label text="Itens do Pedido" style="-fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="comboProduto" promptText="Produto" prefWidth="200" />
        <TextField fx:id="txtQuantidade" promptText="Quantidade" prefWidth="80" />
        <TextField fx:id="txtValorUnitario" promptText="V. Unitário" prefWidth="100" />
        <Button text="Adicionar" onAction="#adicionarItem" style="-fx-background-color: #1a237e; -fx-text-fill: white;" />
        <Button text="Remover" onAction="#removerItem" />
    </HBox>

    <TableView fx:id="tabelaItens" VBox.vgrow="ALWAYS" prefHeight="150">
        <columns>
            <TableColumn fx:id="colProduto" text="Produto" prefWidth="250" />
            <TableColumn fx:id="colQuantidade" text="Quantidade" prefWidth="80" />
            <TableColumn fx:id="colValorUnitario" text="Valor Unitário" prefWidth="120" />
            <TableColumn fx:id="colValorTotalItem" text="Valor Total" prefWidth="120" />
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Label text="Total do Pedido:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtValorTotalPedido" editable="false" prefWidth="150" style="-fx-background-color: #f0f0f0;" />
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Salvar" onAction="#salvar" style="-fx-background-color: #1a237e; -fx-text-fill: white;" />
        <Button text="Cancelar" onAction="#cancelar" />
    </HBox>
</VBox>